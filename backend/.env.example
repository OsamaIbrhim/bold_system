# PostgreSQL. Use a dedicated database such as bold_pos for development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bold_pos"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bold_pos"

# Required: replace with unique random values of at least 32 characters.
JWT_SECRET="6aaee9e495100bb3f400f8f5462fc91eb6b1922f468cd47e7186a18d67721e47"
# Current signing key first; keep the previous key temporarily during rotation.
PRICE_SNAPSHOT_SECRETS=55f57d3269f136d8075c01d52a8e3eb072493cc382a38e58630d5fea9aa60e4d
JWT_EXPIRES="15m"
REFRESH_EXPIRES="30d"

PORT=3000
CORS_ORIGINS="http://localhost:3001,http://localhost:5173,file://,null"
AUTH_RECHECK_TTL_MS=1000
LIST_COUNT_CACHE_MS=5000
SLOW_REQUEST_MS=500
HTTP_TIMING_LOGS=false
POS_ONLINE_THRESHOLD_MS=90000
POS_ENROLLMENT_TTL_MS=600000
