# Environment identity.
NODE_ENV="development"

# PostgreSQL. Prisma runtime traffic uses a bounded pool instead of deriving a
# potentially oversized pool from host CPU count. DIRECT_URL remains reserved
# for migrations and administration.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bold_pos?connection_limit=5&pool_timeout=10&connect_timeout=15"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bold_pos?connect_timeout=30"
DB_POOL_WARM_CONNECTIONS=5

# Generate three DIFFERENT secrets with: openssl rand -hex 32
# Copying these placeholders into a runtime .env intentionally fails startup.
JWT_SECRET="REPLACE_WITH_A_UNIQUE_64_HEX_JWT_SECRET"

# First entry signs new snapshots. Additional entries verify snapshots created
# before a controlled rotation. Key ids are stored in every new signed token.
PRICE_SNAPSHOT_KEYS="price-YYYY-MM=REPLACE_WITH_A_DIFFERENT_64_HEX_PRICE_SECRET"

# Only for two-part price tokens issued before key ids were introduced.
# Configure these only during a short, controlled migration window.
PRICE_SNAPSHOT_LEGACY_SECRETS=""
PRICE_SNAPSHOT_LEGACY_ACCEPT_UNTIL=""

# Dedicated keyring for server-signed cashier/shift sessions used by offline sales.
# First entry signs new tickets; additional entries verify tickets issued before rotation.
POS_OFFLINE_TICKET_KEYS="offline-YYYY-MM=REPLACE_WITH_A_THIRD_64_HEX_OFFLINE_TICKET_SECRET"
POS_OFFLINE_TICKET_TTL_MS=86400000
POS_OFFLINE_CLOCK_SKEW_MS=300000

JWT_EXPIRES="15m"
REFRESH_EXPIRES="30d"

PORT=3000
CORS_ORIGINS="http://localhost:3001,http://localhost:5173,file://,null"
AUTH_RECHECK_TTL_MS=1000
LIST_COUNT_CACHE_MS=5000
SLOW_REQUEST_MS=500
HTTP_TIMING_LOGS=false
POS_ONLINE_THRESHOLD_MS=90000
POS_ENROLLMENT_TTL_MS=600000
POS_PRICE_CATALOG_TTL_MS=86400000

SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
REPORT_EMAIL_TO=""
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
REPORT_WHATSAPP_TO=""
