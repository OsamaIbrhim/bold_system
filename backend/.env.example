# PostgreSQL. Use a dedicated database such as bold_pos for development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bold_pos"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bold_pos"

# Required: replace with a unique random value of at least 32 characters.
JWT_SECRET="change-me-use-openssl-rand-hex-32"
JWT_EXPIRES="15m"
REFRESH_EXPIRES="30d"

PORT=3000
CORS_ORIGINS="http://localhost:3001,http://localhost:5173,file://,null"

# A short authorization cache coalesces bursts while user disable/role changes
# still take effect quickly. Set 0 to recheck PostgreSQL on every request.
AUTH_RECHECK_TTL_MS=1000
LIST_COUNT_CACHE_MS=5000
SLOW_REQUEST_MS=500
HTTP_TIMING_LOGS=false

POS_ONLINE_THRESHOLD_MS=90000
POS_ENROLLMENT_TTL_MS=600000

# Optional reporting integrations.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
REPORT_EMAIL_TO=""
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
REPORT_WHATSAPP_TO=""
