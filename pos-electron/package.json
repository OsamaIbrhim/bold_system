{
  "name": "bold-pos-electron",
  "version": "1.2.0",
  "description": "Bold POS – Electron Offline – sql.js",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "test": "vitest run",
    "test:soft": "npm test && npm run build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "axios": "^1.7.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "6.4.3",
    "electron": "39.8.5",
    "electron-builder": "26.15.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.4.0",
    "vitest": "3.2.6",
    "copyfiles": "^2.4.1"
  },
  "build": {
    "appId": "eg.bold.pos",
    "productName": "Bold POS",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ]
  }
}
